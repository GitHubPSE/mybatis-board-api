<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mybatis_crud.board.mapper.UserMapper">

    <!--로그인 아이디로 사용자 조회 (로그인/중복확인용)-->
    <select id="findById" parameterType="String" resultType="com.mybatis_crud.board.dto.UserDto">
        SELECT id, password, reg_date
        FROM users
        WHERE id = #{id}
    </select>

    <!--회원가입-->
    <insert id="insertUser" parameterType="com.mybatis_crud.board.dto.UserDto">
        INSERT INTO users
        (id, password)
        VALUES
        (#{id}, #{password})
    </insert>
</mapper>
